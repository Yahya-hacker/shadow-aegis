# =============================================================================
# NEXUS PLATFORM - PRODUCTION CONFIGURATION
# =============================================================================
# Modern stack: LangGraph + LiteLLM + E2B
# =============================================================================

# =============================================================================
# LiteLLM CONFIGURATION (Required)
# =============================================================================
# OpenRouter as primary provider
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: Direct provider keys for fallbacks
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Model routing (LiteLLM format: provider/model)
STRATEGIC_MODEL=openrouter/deepseek/deepseek-r1
REASONING_MODEL=openrouter/deepseek/deepseek-r1
CODE_MODEL=openrouter/qwen/qwen-2.5-72b-instruct
VISUAL_MODEL=openrouter/qwen/qwen2.5-vl-72b-instruct

# LiteLLM settings
LITELLM_LOG=INFO
LITELLM_FALLBACKS=true

# =============================================================================
# E2B CONFIGURATION (Required for sandboxed execution)
# =============================================================================
# Get your key at: https://e2b.dev
E2B_API_KEY=your_e2b_api_key

# Sandbox settings
E2B_SANDBOX_TIMEOUT=300
E2B_TEMPLATE=base

# =============================================================================
# GENERATION PARAMETERS
# =============================================================================
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# =============================================================================
# EPISTEMIC SETTINGS
# =============================================================================
# Confidence threshold for exploitation mode
EPISTEMIC_THRESHOLD=0.6

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_PATH=data/nexus.db

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# LEGACY COMPATIBILITY (Optional)
# =============================================================================
# For local model support via ngrok tunnel
# LOCAL_MODEL_MODE=true
# OPENROUTER_BASE_URL=https://your-ngrok-url.ngrok-free.app/v1
